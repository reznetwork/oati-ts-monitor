#!/bin/sh
set -e

case "$1" in
    purge)
        if getent passwd oati-ts-monitor >/dev/null 2>&1; then
            deluser oati-ts-monitor || true
        fi
        if getent group oati-ts-monitor >/dev/null 2>&1; then
            delgroup oati-ts-monitor || true
        fi
        ;;
esac

#DEBHELPER#

exit 0
